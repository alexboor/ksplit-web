---
import Legal from '../layouts/Legal.astro';

const sections = [
  { num: 1, color: '#A78BF5', bg: 'rgba(124,85,240,0.15)', border: 'rgba(124,85,240,0.25)' },
  { num: 2, color: '#7EB8F7', bg: 'rgba(126,184,247,0.12)', border: 'rgba(126,184,247,0.22)' },
  { num: 3, color: '#A78BF5', bg: 'rgba(124,85,240,0.15)', border: 'rgba(124,85,240,0.25)' },
  { num: 4, color: '#D060CF', bg: 'rgba(208,96,207,0.12)', border: 'rgba(208,96,207,0.22)' },
  { num: 5, color: '#7EB8F7', bg: 'rgba(126,184,247,0.12)', border: 'rgba(126,184,247,0.22)' },
  { num: 6, color: '#A78BF5', bg: 'rgba(124,85,240,0.15)', border: 'rgba(124,85,240,0.25)' },
  { num: 7, color: '#D060CF', bg: 'rgba(208,96,207,0.12)', border: 'rgba(208,96,207,0.22)' },
  { num: 8, color: '#7EB8F7', bg: 'rgba(126,184,247,0.12)', border: 'rgba(126,184,247,0.22)' },
  { num: 9, color: '#A78BF5', bg: 'rgba(124,85,240,0.15)', border: 'rgba(124,85,240,0.25)' },
];
---

<Legal title="Privacy Policy" lastUpdated="June 21, 2025">
  <!-- Intro -->
  <p class="text-[16px] leading-[1.8] text-[rgba(238,238,248,0.6)] mb-14">
    Welcome to <strong class="text-[#EEEEF8] font-semibold">KeepSplit</strong> ("we", "our", or "us"). We are committed to protecting your personal information. This Privacy Policy explains what data we collect, how we use it, and your rights. By using KeepSplit, you agree to the practices described in this policy.
  </p>

  <!-- 1. Information We Collect -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[0].bg};border:1px solid ${sections[0].border};color:${sections[0].color}`}>1</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Information We Collect</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)] mb-4">We collect the following types of information when you use KeepSplit:</p>
      <div class="flex flex-col gap-[14px]">
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Account Information</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">Your name and email address when you create an account or sign in.</p>
        </div>
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Group &amp; Expense Data</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">Groups you create or join, expense descriptions, amounts, split configurations, and settlement records.</p>
        </div>
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Usage &amp; Device Data</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">Basic analytics about how you use the app (screens visited, actions taken), your device type, OS version, and app version. We do not collect precise location data.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 2. How We Use Your Information -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[1].bg};border:1px solid ${sections[1].border};color:${sections[1].color}`}>2</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">How We Use Your Information</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)] mb-5">We use your information solely to provide and improve KeepSplit:</p>
      <ul class="flex flex-col gap-3 list-none">
        {[
          'To operate the expense-tracking and settlement features of the app',
          'To send you notifications about new expenses, balance updates, and settlements in your groups',
          'To diagnose issues, improve performance, and develop new features',
          'To respond to your support requests and communications',
        ].map((item) => (
          <li class="flex items-start gap-3 text-[15px] leading-[1.7] text-[rgba(238,238,248,0.58)]">
            <span class="w-[6px] h-[6px] rounded-full flex-shrink-0 mt-[10px] block" style="background:linear-gradient(135deg,#7EB8F7,#7C55F0)"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 3. Information Sharing -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[2].bg};border:1px solid ${sections[2].border};color:${sections[2].color}`}>3</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Information Sharing</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)] mb-5">
        <strong class="text-[#EEEEF8] font-semibold">We do not sell your personal data.</strong> We share information only in these limited cases:
      </p>
      <div class="flex flex-col gap-[14px]">
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Within your groups</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">Members of a group can see the group's expenses, balances, and settlement history. Your name is visible to other members in groups you join.</p>
        </div>
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Service Providers</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">We use trusted third-party providers for hosting, crash reporting, and analytics. These providers process data only on our behalf and under strict confidentiality obligations.</p>
        </div>
        <div class="px-5 py-[18px] rounded-[14px] bg-surface border border-white/[0.06]">
          <p class="text-[14px] font-semibold text-[#EEEEF8] mb-[6px]">Legal Requirements</p>
          <p class="text-[14.5px] leading-[1.7] text-[rgba(238,238,248,0.52)]">We may disclose data if required by law, court order, or to protect the rights and safety of our users or the public.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 4. Data Security -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[3].bg};border:1px solid ${sections[3].border};color:${sections[3].color}`}>4</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Data Security</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)]">We implement industry-standard security measures to protect your data, including encryption in transit (TLS) and at rest. While we take reasonable precautions, no method of transmission over the internet is 100% secure. We encourage you to use a strong, unique password for your KeepSplit account.</p>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 5. Data Retention -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[4].bg};border:1px solid ${sections[4].border};color:${sections[4].color}`}>5</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Data Retention</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)]">We retain your account and group data for as long as your account is active. If you delete your account, we will permanently remove your personal information within 30 days, except where retention is required by law. Anonymized, aggregate usage data may be retained for longer periods to help us improve the app.</p>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 6. Your Rights -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[5].bg};border:1px solid ${sections[5].border};color:${sections[5].color}`}>6</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Your Rights</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)] mb-5">Depending on your location, you may have the following rights regarding your personal data:</p>
      <ul class="flex flex-col gap-3 list-none mb-5">
        {[
          { label: 'Access', text: 'Request a copy of the personal data we hold about you' },
          { label: 'Correction', text: 'Ask us to correct inaccurate or incomplete data' },
          { label: 'Deletion', text: 'Delete your account and associated personal data from within the app settings' },
          { label: 'Portability', text: 'Request an export of your expense and group data in a machine-readable format' },
          { label: 'Opt-out', text: 'Disable push notifications at any time through your device settings' },
        ].map(({ label, text }) => (
          <li class="flex items-start gap-3 text-[15px] leading-[1.7] text-[rgba(238,238,248,0.58)]">
            <span class="w-[6px] h-[6px] rounded-full flex-shrink-0 mt-[10px] block" style="background:linear-gradient(135deg,#7C55F0,#D060CF)"></span>
            <span><strong class="text-[#EEEEF8] font-semibold">{label}:</strong> {text}</span>
          </li>
        ))}
      </ul>
      <p class="text-[15px] leading-[1.8] text-[rgba(238,238,248,0.5)]">To exercise any of these rights, contact us at the email address below.</p>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 7. Children's Privacy -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[6].bg};border:1px solid ${sections[6].border};color:${sections[6].color}`}>7</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Children's Privacy</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)]">KeepSplit is not intended for use by children under the age of 13. We do not knowingly collect personal information from children. If we become aware that a child under 13 has provided us with personal data, we will take steps to delete such information promptly.</p>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 8. Changes to This Policy -->
  <section class="mb-[52px]">
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[7].bg};border:1px solid ${sections[7].border};color:${sections[7].color}`}>8</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Changes to This Policy</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)]">We may update this Privacy Policy from time to time. When we make material changes, we will notify you through the app or by email, and update the "Last updated" date at the top of this page. Continued use of KeepSplit after changes take effect constitutes acceptance of the revised policy.</p>
    </div>
  </section>

  <div class="h-px bg-white/[0.05] mb-[52px]"></div>

  <!-- 9. Contact Us -->
  <section>
    <div class="flex items-center gap-[14px] mb-5">
      <span class="inline-flex items-center justify-center w-[30px] h-[30px] rounded-[8px] text-[13px] font-bold flex-shrink-0"
        style={`background:${sections[8].bg};border:1px solid ${sections[8].border};color:${sections[8].color}`}>9</span>
      <h2 class="text-[22px] font-bold tracking-[-0.5px] text-[#EEEEF8]">Contact Us</h2>
    </div>
    <div class="pl-11">
      <p class="text-[15.5px] leading-[1.8] text-[rgba(238,238,248,0.58)] mb-6">If you have any questions, concerns, or requests regarding this Privacy Policy or your personal data, please contact us:</p>
      <div class="inline-flex items-center gap-3 px-6 py-[18px] rounded-[16px]"
        style="background:rgba(124,85,240,0.08);border:1px solid rgba(124,85,240,0.22)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A78BF5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <a href="mailto:privacy@KeepSplit.app" class="text-[15px] font-semibold text-[#A78BF5] no-underline hover:text-[#EEEEF8] transition-colors duration-200">
          privacy@KeepSplit.app
        </a>
      </div>
    </div>
  </section>
</Legal>
