---
interface Props {
  title: string;
  description: string;
  accentColor: string;
  accentBg: string;
  accentBorder: string;
  icon: string;
  highlighted?: boolean;
  wide?: boolean;
}
const { title, description, accentColor, accentBg, accentBorder, icon, highlighted = false, wide = false } = Astro.props;
---

<div
  data-animate
  class:list={[
    'group p-9 rounded-[24px] border transition-all duration-[250ms] cursor-default',
    wide ? 'md:col-span-2' : '',
    highlighted
      ? 'bg-gradient-to-br from-[rgba(124,85,240,0.14)] to-[rgba(208,96,207,0.08)] border-[rgba(124,85,240,0.25)] hover:border-[rgba(124,85,240,0.55)]'
      : 'bg-surface border-white/[0.06] hover:border-[rgba(124,85,240,0.3)]',
    'hover:-translate-y-1',
  ]}
>
  {wide ? (
    <div class="flex items-start gap-7">
      <div
        class="w-[52px] h-[52px] rounded-[16px] flex items-center justify-center flex-shrink-0"
        style={`background:${accentBg};border:1px solid ${accentBorder};`}
        set:html={icon}
      />
      <div>
        <h3 class="text-[17px] font-bold tracking-[-0.3px] text-[#EEEEF8] mb-[10px]">{title}</h3>
        <p class="text-[14.5px] leading-[1.65] text-[rgba(238,238,248,0.48)] max-w-[520px]">{description}</p>
      </div>
    </div>
  ) : (
    <>
      <div
        class="w-[52px] h-[52px] rounded-[16px] flex items-center justify-center mb-6"
        style={`background:${accentBg};border:1px solid ${accentBorder};`}
        set:html={icon}
      />
      <h3 class="text-[17px] font-bold tracking-[-0.3px] text-[#EEEEF8] mb-[10px]">{title}</h3>
      <p class:list={['text-[14.5px] leading-[1.65]', highlighted ? 'text-[rgba(238,238,248,0.6)]' : 'text-[rgba(238,238,248,0.48)]']}>{description}</p>
    </>
  )}
</div>
